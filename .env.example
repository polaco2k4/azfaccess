# URL do projeto Supabase (Project Settings -> API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave pública "anon" (Project Settings -> API) — usada para login (auth.signInWithPassword)
SUPABASE_ANON_KEY=

# Chave "service_role" (Project Settings -> API) — NUNCA expor ao browser.
# Usada pelo servidor para aceder à base de dados, Storage e Admin API do Auth.
SUPABASE_SERVICE_ROLE_KEY=

PORT=3000
